// ====================================================================
// SETUP PUSAT
// ====================================================================
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // URL dikelola via prisma.config.ts demi kepatuhan versi terbaru
}

// ====================================================================
// ENUMS (Tipe Data Konstan)
// ====================================================================
enum LevelJLPT {
  N5
  N4
  N3
  N2
  N1
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
}

enum QuestionType {
  QUIZ
  TRYOUT
}

enum CategoryType {
  KANJI
  KOSAKATA
  TATA_BAHASA
}

enum LmsRole {
  LMS_STUDENT
  LMS_ADMIN
}

enum LmsBadgeUnlockRule {
  MANUAL
  FIRST_LESSON
  FIRST_QUIZ
  TRYOUT_PASS
}

enum LmsNotificationType {
  ENROLLMENT_PENDING
  ENROLLMENT_APPROVED
  ENROLLMENT_REJECTED
  BADGE_UNLOCKED
  XP_EARNED
  COURSE_GRANTED
}

// ====================================================================
// 1. USER JANGKAR (FK ke Core Service / Clerk User ID)
// XP & level global → Core. Poin LMS, badge, display name → DB LMS. Lihat docs/ECOSYSTEM.md
// ====================================================================
model User {
  id              String   @id // Clerk User ID — tanpa @default(uuid())
  /// Nama tampilan di LMS (bukan nama Google SSO dari Clerk)
  displayName     String?  @db.VarChar(32)
  /// Bio singkat profil belajar
  bio             String?  @db.VarChar(280)
  /// Foto profil LMS — override Clerk jika di-set
  avatarUrl       String?
  role            LmsRole  @default(LMS_STUDENT)
  equippedBadgeId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  equippedBadge   LmsBadge? @relation("EquippedBadge", fields: [equippedBadgeId], references: [id], onDelete: SetNull)
  enrollments     Enrollment[]
  progress     UserProgress[]
  attempts     QuizAttempt[]
  lmsStats        UserLmsStats?
  pointEvents     LmsPointEvent[]
  xpEvents        LmsXpEvent[]
  badges          UserBadge[]
  notifications   LmsNotification[]
  lessonComments  LessonComment[]
  commentReplies  LessonCommentReply[]
}

// ====================================================================
// 1b. GAMIFIKASI LMS (poin leaderboard & badge — bukan di Core)
// ====================================================================
model UserLmsStats {
  userId    String   @id
  lmsPoints Int      @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lmsPoints(sort: Desc), updatedAt(sort: Asc)])
}

model LmsPointEvent {
  id           String   @id @default(uuid())
  userId       String
  pointsGained Int
  /// Idempotency — mis. "lesson:{lessonId}" atau "quiz:{attemptId}"
  sourceKey    String   @unique
  sourceType   String
  sourceId     String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

/// Log XP lokal untuk grafik mingguan — mirror award Core (atau dev fallback).
model LmsXpEvent {
  id         String   @id @default(uuid())
  userId     String
  xpGained   Int
  sourceKey  String   @unique
  sourceType String
  sourceId   String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

model LmsNotification {
  id        String               @id @default(uuid())
  userId    String
  type      LmsNotificationType
  title     String
  body      String?
  href      String?
  dedupeKey String?
  readAt    DateTime?
  createdAt DateTime             @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@index([userId, readAt, createdAt(sort: Desc)])
}

model LmsBadge {
  id              String             @id @default(uuid())
  code            String             @unique
  title           String
  description     String?            @db.Text
  imageUrl        String?
  sortOrder       Int                @default(0)
  unlockRule      LmsBadgeUnlockRule @default(MANUAL)
  /// Nilai tambahan — mis. skor minimum untuk TRYOUT_PASS
  unlockValue     Int?
  xpBonus         Int                @default(25)
  requirementText String?
  createdAt       DateTime           @default(now())

  userBadges      UserBadge[]
  equippedByUsers User[]             @relation("EquippedBadge")
}

model UserBadge {
  id             String   @id @default(uuid())
  userId         String
  badgeId        String
  unlockedAt     DateTime @default(now())
  xpBonusAwarded Boolean  @default(false)

  user  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge LmsBadge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

// ====================================================================
// 2. HIRARKI KURSUS & PEMBAYARAN (CMS)
// ====================================================================
model Course {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  description String?   @db.Text
  level       LevelJLPT @default(N5)
  /// Kategori tampilan katalog (Kosa Kata, Tata Bahasa, Kanji, …)
  category    String    @default("Kosa Kata")
  /// Harga dalam Rupiah (0 = gratis)
  priceIdr    Int       @default(0)
  isPublished Boolean   @default(false)
  isFeatured  Boolean   @default(false)
  createdAt   DateTime  @default(now())

  modules     Module[]
  enrollments Enrollment[]
}

model Module {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  slug        String
  order       Int
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@unique([courseId, slug])
  @@unique([courseId, order])
  @@index([courseId])
}

model Enrollment {
  id        String           @id @default(uuid())
  userId    String
  courseId  String
  status    EnrollmentStatus @default(PENDING)
  createdAt DateTime         @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Lesson {
  id       String  @id @default(uuid())
  moduleId String
  title    String
  slug     String  @unique
  order    Int
  content  String? @db.Text
  videoUrl String?

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  kanjis      MaterialKanji[]
  kosakatas   MaterialKosakata[]
  tataBahasas MaterialTataBahasa[]

  questions Question[]
  progress  UserProgress[]
  attempts  QuizAttempt[]
  comments  LessonComment[]

  @@unique([moduleId, slug])
  @@index([moduleId])
}

model LessonComment {
  id        String   @id @default(uuid())
  lessonId  String
  userId    String
  content   String   @db.Text
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lesson  Lesson               @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user    User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies LessonCommentReply[]

  @@index([lessonId, createdAt(sort: Desc)])
}

model LessonCommentReply {
  id           String   @id @default(uuid())
  commentId    String
  userId       String
  content      String   @db.Text
  likes        Int      @default(0)
  isInstructor Boolean  @default(false)
  createdAt    DateTime @default(now())

  comment LessonComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([commentId, createdAt(sort: Asc)])
}

// ====================================================================
// 4. MASTER DATA KATEGORI (NORMALISASI 3NF)
// ====================================================================
model Category {
  id   String       @id @default(uuid())
  name String
  type CategoryType

  kanjis      MaterialKanji[]
  kosakatas   MaterialKosakata[]
  tataBahasas MaterialTataBahasa[]

  @@unique([name, type])
}

// ====================================================================
// 5. MATERI PEMBELAJARAN
// ====================================================================
model MaterialKanji {
  id            String  @id @default(uuid())
  lessonId      String
  categoryId    String?
  huruf         String
  furigana      String?
  romaji        String?
  arti          String
  onyomi        String?
  contohOnyomi  String?
  artiOnyomi    String?
  kunyomi       String?
  contohKunyomi String?
  artiKunyomi   String?

  lesson   Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

model MaterialKosakata {
  id            String  @id @default(uuid())
  lessonId      String
  categoryId    String?
  kosakata      String
  furigana      String?
  romaji        String?
  arti          String
  contohKalimat String? @db.Text

  lesson   Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

model MaterialTataBahasa {
  id            String  @id @default(uuid())
  lessonId      String
  categoryId    String?
  tataBahasa    String
  arti          String
  contohKalimat String? @db.Text

  lesson   Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

// ====================================================================
// 6. BANK SOAL, KUIS & TRYOUT (NORMALISASI OPSI JAWABAN)
// ====================================================================
model TryoutSession {
  id               String    @id @default(uuid())
  code             String    @unique
  title            String
  phaseLabel       String
  description      String?   @db.Text
  scheduledAt      DateTime?
  isActive         Boolean   @default(true)
  sortOrder        Int       @default(0)
  timeLimitMinutes Int       @default(120)
  createdAt        DateTime  @default(now())

  questions Question[]
}

model LiveClass {
  id          String    @id @default(uuid())
  title       String
  description String    @db.Text
  senseiName  String
  senseiLevel String?
  category    String
  level       LevelJLPT
  scheduledAt DateTime
  endsAt      DateTime?
  maxSlots    Int       @default(30)
  filledSlots Int       @default(0)
  thumbUrl    String?
  meetingUrl  String?
  isPublished Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@index([scheduledAt])
  @@index([isPublished, scheduledAt])
}

model Question {
  id           String       @id @default(uuid())
  lessonId     String? // Optional: kosong jika ini soal Tryout
  tryoutSessionId String?
  tryoutLevel  LevelJLPT?
  /// MOJI_GOI | BUNPOU_DOKKAI | CHOKAI
  tryoutSection String?
  sortOrder    Int          @default(0)
  type         QuestionType @default(QUIZ)
  questionText String       @db.Text
  explanation  String?      @db.Text
  xpReward     Int          @default(10) // Nilai usulan reward; pemberian XP ke user via Core Service

  lesson        Lesson?        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  tryoutSession TryoutSession? @relation(fields: [tryoutSessionId], references: [id], onDelete: Cascade)
  options       QuestionOption[]

  @@index([tryoutSessionId, tryoutLevel, sortOrder])
}

model QuestionOption {
  id         String  @id @default(uuid())
  questionId String
  text       String
  isCorrect  Boolean @default(false)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

// ====================================================================
// 7. TRACKING PROGRESS SISWA
// ====================================================================
model UserProgress {
  id          String   @id @default(uuid())
  userId      String
  lessonId    String
  isCompleted Boolean  @default(true)
  completedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model QuizAttempt {
  id        String       @id @default(uuid())
  userId    String
  lessonId  String? // Optional: Kosong jika ini percobaan Tryout
  type      QuestionType @default(QUIZ)
  score     Int
  createdAt DateTime     @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)
}
