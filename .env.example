# =============================================================================
# JepangKu LMS — Environment variables (template)
# =============================================================================
# Copy: cp .env.example .env
# Arsitektur: docs/ECOSYSTEM.md
# Core shared env (Sultan): map keys below — jangan salin secret Core ke LMS.
# =============================================================================

# -----------------------------------------------------------------------------
# At current progress (~40% MVP)
# -----------------------------------------------------------------------------
# | Variable                         | Status    | Used by / maps to Core        |
# |----------------------------------|-----------|-------------------------------|
# | DATABASE_URL                     | REQUIRED  | lib/prisma.ts (LMS DB only)   |
# | PG_POOL_MAX                      | optional  | lib/prisma.ts (default: 10)   |
# | JEPANGKU_CORE_API_URL            | REQUIRED* | lib/core/client.ts → CORE URL |
# | JEPANGKU_CORE_SERVICE_TOKEN      | REQUIRED* | award XP → CORE_SERVICE_TOKEN |
# | JEPANGKU_CORE_JWT_PUBLIC_KEY     | REQUIRED* | verify JWT (public PEM)       |
# | JEPANGKU_CORE_JWT_ISSUER         | REQUIRED* | → JWT_ISSUER                  |
# | JEPANGKU_CORE_JWT_AUDIENCE       | REQUIRED* | → JWT_AUDIENCE                |
# | JEPANGKU_CORE_JWT_EXPIRATION     | optional  | → JWT_EXPIRATION (seconds)    |
# | NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY| REQUIRED  | → CLERK_PUBLISHABLE_KEY       |
# | CLERK_SECRET_KEY                 | REQUIRED  | server Clerk (same app)       |
# | NEXT_PUBLIC_APP_URL              | optional  | ngrok / prod LMS origin       |
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Database LMS (PostgreSQL) — REQUIRED
# -----------------------------------------------------------------------------
DATABASE_URL="YOUR_DATABASE_URL"
PG_POOL_MAX=10

# -----------------------------------------------------------------------------
# JepangKu Core Backend — docs/backend_core_services/core_openapi.json
# -----------------------------------------------------------------------------
JEPANGKU_CORE_API_URL=YOUR_CORE_API_URL

# Server-to-server LMS → Core (Authorization: Bearer …)
JEPANGKU_CORE_SERVICE_TOKEN=YOUR_CORE_SERVICE_TOKEN

# RS256 public key from Sultan (pair of Core JWT_PRIVATE_KEY; use \n for newlines)
JEPANGKU_CORE_JWT_PUBLIC_KEY="YOUR_JWT_PUBLIC_KEY_PEM"
JEPANGKU_CORE_JWT_ISSUER=YOUR_JWT_ISSUER
JEPANGKU_CORE_JWT_AUDIENCE=YOUR_JWT_AUDIENCE
JEPANGKU_CORE_JWT_EXPIRATION=YOUR_JWT_EXPIRATION_SECONDS

# -----------------------------------------------------------------------------
# Clerk — same Clerk app as Core (webhook secret stays on Core only)
# -----------------------------------------------------------------------------
# Clerk — same Clerk app as Core (webhook secret tetap di Core)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=YOUR_CLERK_PUBLISHABLE_KEY
CLERK_SECRET_KEY=YOUR_CLERK_SECRET_KEY
# Wajib URL absolut saat pakai custom sign-in (hindari redirect ke accounts.dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=https://YOUR_NGROK_HOST/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=https://YOUR_NGROK_HOST/sign-up
# Clerk Dashboard → Redirect URLs (allow list):
#   https://YOUR_NGROK_HOST/auth/sso-callback
#   https://YOUR_NGROK_HOST/auth/complete
#   https://YOUR_NGROK_HOST/sign-in/sso-callback  (legacy, optional)

# -----------------------------------------------------------------------------
# App URL — SSO testing: pakai ngrok (bukan localhost) jika URL sudah di Clerk + Core CORS
# -----------------------------------------------------------------------------
# Dev SSO: https://walk-ravine-smuggler.ngrok-free.dev (contoh stable tunnel)
# UI-only tanpa OAuth: http://localhost:3000
NEXT_PUBLIC_APP_URL=YOUR_APP_URL

# -----------------------------------------------------------------------------
# Redis (optional — belum di-wire; cache session, rate limit, ISR)
# -----------------------------------------------------------------------------
# Local tanpa password: redis://localhost:6379
# Dengan password (compose): redis://:YOUR_REDIS_PASSWORD@localhost:6379
REDIS_ENABLED=false
REDIS_URL=YOUR_REDIS_URL
REDIS_KEY_PREFIX=jepangku:lms:
