# =============================================================================
# JepangKu LMS — Environment variables (template)
# =============================================================================
# Copy: cp .env.example .env
# Arsitektur: docs/ECOSYSTEM.md
# Core token wiring: docs/CORE_INTEGRATION_STATUS.md
# =============================================================================

# -----------------------------------------------------------------------------
# Variable reference
# -----------------------------------------------------------------------------
# | Variable                          | Token wiring | Used by                    |
# |-----------------------------------|--------------|----------------------------|
# | DATABASE_URL                      | REQUIRED     | lib/prisma.ts (LMS DB)     |
# | PG_POOL_MAX                       | optional     | lib/prisma.ts (default 10) |
# | PG_CONNECTION_TIMEOUT_MS          | optional     | lib/prisma.ts (default 10000)|
# | LOG_LEVEL                         | optional     | lib/logger (debug dev, info prod) |
# | LOG_FILE                          | optional     | default logs/jepangku-lms.log     |
# | LOG_TO_FILE                       | optional     | set false to disable file logging |
# | JEPANGKU_CORE_API_URL             | REQUIRED     | lib/core/client.ts         |
# | NEXT_PUBLIC_CORE_INTEGRATION_UI   | optional     | Core banner + /auth/complete (default off) |
# | JEPANGKU_CORE_JWT_PUBLIC_KEY      | REQUIRED     | lib/core/verify-jwt.ts     |
# | JEPANGKU_CORE_JWT_ISSUER          | REQUIRED     | verify Core JWT            |
# | JEPANGKU_CORE_JWT_AUDIENCE        | REQUIRED     | verify Core JWT            |
# | JEPANGKU_CORE_SERVICE_TOKEN       | later        | award XP (gamification)    |
# | JEPANGKU_CORE_JWT_EXPIRATION      | unused       | cookie maxAge = 7d in code |
# | NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY | REQUIRED     | ClerkProvider              |
# | CLERK_SECRET_KEY                  | REQUIRED     | server auth (same app Core)|
# | NEXT_PUBLIC_APP_URL               | recommended  | OAuth redirect, cookie secure|
# | NEXT_PUBLIC_CLERK_SIGN_IN_URL     | optional     | fallback: APP_URL/sign-in  |
# | NEXT_PUBLIC_CLERK_SIGN_UP_URL     | optional     | fallback: APP_URL/sign-up  |
# | LMS_DEV_ADMIN_BYPASS              | dev only     | proxy.ts — skip Core admin role check |
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Database LMS (PostgreSQL) — REQUIRED
# After schema changes: bun run db:push
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:@localhost:5432/jepangku_lms?schema=public"
PG_POOL_MAX=10

# -----------------------------------------------------------------------------
# JepangKu Core Backend
# Production: https://core.jepangku.com (Clerk pk_live / sk_live)
# Staging (dev LMS + ngrok): https://core-staging.jepangku.com — Clerk pk_test (Sultan)
# Dev LMS (ngrok) TIDAK bisa pakai Core prod — Clerk live hanya domain *.jepangku.com
# -----------------------------------------------------------------------------
# Local Core: http://localhost:8080
# Staging (dev LMS + ngrok): https://core-staging.jepangku.com — Clerk pk_test (Sultan)
# Production: https://core.jepangku.com — Clerk pk_live (*.jepangku.com only)
JEPANGKU_CORE_API_URL=http://localhost:8080

# UI banner + Core JWT sync (CoreSessionSync). Default off — staging CI bakes `true`.
# NEXT_PUBLIC_* is inlined at Docker build; VPS .env alone does NOT enable client sync.
# NEXT_PUBLIC_CORE_INTEGRATION_UI=false

# Verify Core JWT — MUST be PUBLIC KEY (SPKI), NOT JWT_PRIVATE_KEY
# Generate from Core: cd jepangku-core && bun run jwt:export-public-key
JEPANGKU_CORE_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_BASE64_KEY_BODY\n-----END PUBLIC KEY-----"
# Must match JWT_ISSUER in jepangku-core/.env (same for local & prod)
JEPANGKU_CORE_JWT_ISSUER=https://core.jepangku.com
JEPANGKU_CORE_JWT_AUDIENCE=jepangku

# Server-to-server — POST /api/v1/gamification/award (not needed for login/token)
JEPANGKU_CORE_SERVICE_TOKEN=YOUR_CORE_SERVICE_TOKEN

# Optional — not read by LMS yet (cookie maxAge hardcoded 7d in lib/auth/constants.ts)
# JEPANGKU_CORE_JWT_EXPIRATION=86400

# -----------------------------------------------------------------------------
# Clerk — same Clerk app as Core & Portal Berita (webhook secret stays on Core)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=YOUR_CLERK_PUBLISHABLE_KEY
CLERK_SECRET_KEY=YOUR_CLERK_SECRET_KEY

# -----------------------------------------------------------------------------
# App URL — OAuth / secure cookies
# -----------------------------------------------------------------------------
# Production: https://kursus.jepangku.com
# Dev SSO (ngrok): must match Clerk Dashboard redirect URLs + Core CORS_ORIGINS
NEXT_PUBLIC_APP_URL=https://YOUR_NGROK_OR_PROD_HOST

# Optional — only if APP_URL is wrong but you need custom sign-in/up URLs
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=https://YOUR_HOST/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=https://YOUR_HOST/sign-up
#
# Clerk Dashboard → Redirect URLs (allow list):
#   https://YOUR_HOST/auth/sso-callback
#   https://YOUR_HOST/dashboard

# -----------------------------------------------------------------------------
# Local dev — admin panel without Core LMS_ADMIN role
# Requires NODE_ENV=development (bun dev). Never set on staging/production.
# After adding to .env: restart dev server, sign in with Clerk, open /admin
# -----------------------------------------------------------------------------
# LMS_DEV_ADMIN_BYPASS=true

# -----------------------------------------------------------------------------
# Staging / production — admin LMS pertama (Clerk user id)
# User ini otomatis dapat role LMS_ADMIN saat pertama login / sync jangkar.
# Admin tersebut lalu bisa promote user lain via /admin/users.
# Set sebelum login pertama user tersebut. Jangan set di dev (pakai bypass di atas).
# -----------------------------------------------------------------------------
# LMS_BOOTSTRAP_ADMIN_USER_ID=user_xxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Manual payment (transfer bank) — Phase 1 MVP
# -----------------------------------------------------------------------------
PAYMENT_BANK_NAME=BCA
PAYMENT_ACCOUNT_NAME=PT Jepangku Indonesia
PAYMENT_ACCOUNT_NUMBER=1234567890

# -----------------------------------------------------------------------------
# Partner API — read-only published course catalog (server-to-server)
# Generate: openssl rand -hex 32
# Header: Authorization: Bearer <key>  OR  X-LMS-API-Key: <key>
# Endpoints: GET /api/v1/public/courses , GET /api/v1/public/courses/[slug]
# Leave unset to disable partner API (returns 503).
# -----------------------------------------------------------------------------
# LMS_PARTNER_API_KEY=

# -----------------------------------------------------------------------------
# Cloudflare R2 — badge assets (LMS admin CMS)
# Minta akses dari tim infra / Cloudflare dashboard JepangKu
# -----------------------------------------------------------------------------
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=          # alias: R2_ACCESS_KEY_SECRET
# R2_BUCKET=jepangku             # alias: R2_BUCKET_NAME
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# -----------------------------------------------------------------------------
# Redis (optional — belum di-wire)
# -----------------------------------------------------------------------------
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=jepangku:lms:
