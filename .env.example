# =============================================================================
# JepangKu LMS — Environment variables (template)
# =============================================================================
# Copy this file to `.env` and fill in real values:
#   cp .env.example .env
#
# Never commit `.env` — it is gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL) — required for Prisma & `bun run db:*`
# -----------------------------------------------------------------------------
# Local example (adjust user, password, host, port, database name):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jepangku_lms"

# -----------------------------------------------------------------------------
# Clerk Auth — required when auth is enabled (see docs/PROGRESS.md)
# Get keys: https://dashboard.clerk.com → API Keys
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# Webhook signing secret (Clerk Dashboard → Webhooks → endpoint `/api/webhooks/clerk`)
CLERK_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# Optional: override Clerk hosted paths (defaults match this repo's routes)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# -----------------------------------------------------------------------------
# App (optional)
# -----------------------------------------------------------------------------
# Public base URL for absolute links in emails/webhooks (production)
# NEXT_PUBLIC_APP_URL=http://localhost:3000
