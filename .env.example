# =============================================================================
# JepangKu LMS — Environment variables (template)
# =============================================================================
# Copy this file to `.env` and fill in real values:
#   cp .env.example .env
#
# Arsitektur: docs/ECOSYSTEM.md
# Auth: JWT + claims dari Core (profil/XP/roles) — Clerk di Core Service
# =============================================================================

# -----------------------------------------------------------------------------
# Database LMS (PostgreSQL) — required for Prisma & `bun run db:*`
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jepangku_lms"

# -----------------------------------------------------------------------------
# JepangKu Core Backend
# -----------------------------------------------------------------------------
# API untuk leaderboard, award XP, dll. (bukan untuk profil user aktif — itu JWT claims)
JEPANGKU_CORE_API_URL=http://localhost:4000

# Verifikasi JWT yang diterbitkan Core (isi setelah Sultan publish JWKS / secret)
# JEPANGKU_CORE_JWT_ISSUER=https://core.jepangku.com
# JEPANGKU_CORE_JWKS_URL=https://core.jepangku.com/.well-known/jwks.json
# JEPANGKU_CORE_JWT_AUDIENCE=jepangku-lms

# Optional: service token LMS → Core (server-to-server award XP)
# JEPANGKU_CORE_SERVICE_TOKEN=

# -----------------------------------------------------------------------------
# Clerk di LMS — TIDAK dipakai pada arsitektur final (Clerk hanya di Core)
# -----------------------------------------------------------------------------
# Hanya jika BFF sementara di Next.js selama integrasi:
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...

# -----------------------------------------------------------------------------
# App (optional)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_APP_URL=http://localhost:3000
