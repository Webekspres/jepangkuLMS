# =============================================================================
# JepangKu LMS — Environment variables (template)
# =============================================================================
# Copy: cp .env.example .env
# Arsitektur: docs/ECOSYSTEM.md
# DB policy (dev local, prod TBD): docs/DATABASE.md
# =============================================================================

# -----------------------------------------------------------------------------
# At current progress (~40% MVP, 2026-06-03)
# -----------------------------------------------------------------------------
# | Variable                  | Status    | Used by                          |
# |---------------------------|-----------|----------------------------------|
# | DATABASE_URL              | REQUIRED  | lib/prisma.ts, prisma.config.ts  |
# | PG_POOL_MAX               | optional  | lib/prisma.ts (default: 10)      |
# | JEPANGKU_CORE_API_URL     | stub      | lib/core/client.ts               |
# | JEPANGKU_CORE_JWT_*       | not wired | lib/core/session.ts (TODO)       |
# | JEPANGKU_CORE_SERVICE_TOKEN | not wired | future award-XP API calls      |
# | CLERK_*                   | not used  | auth lives on Core, not LMS      |
# | NEXT_PUBLIC_APP_URL       | optional  | not in code yet                  |
# | NODE_ENV                  | auto      | set by Next.js — do not add      |
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Database LMS (PostgreSQL) — REQUIRED
# -----------------------------------------------------------------------------
DATABASE_URL="YOUR_DATABASE_URL"

# Max connections in pg Pool (lib/prisma.ts). Default: 10
PG_POOL_MAX=10

# -----------------------------------------------------------------------------
# JepangKu Core Backend — docs/backend_core_services/core_openapi.json
# -----------------------------------------------------------------------------
JEPANGKU_CORE_API_URL=YOUR_CORE_API_URL

# Verify Core JWT (RS256 public key from Sultan; use \n for line breaks)
# JEPANGKU_CORE_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# JEPANGKU_CORE_JWT_ISSUER=
# JEPANGKU_CORE_JWT_AUDIENCE=

# Server-to-server LMS → Core (POST /api/v1/gamification/award)
# JEPANGKU_CORE_SERVICE_TOKEN=

# -----------------------------------------------------------------------------
# Clerk on LMS — NOT used (Clerk only on Core Service)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...

# -----------------------------------------------------------------------------
# App URL — set to ngrok stable URL when sharing dev with Core/Clerk
# -----------------------------------------------------------------------------
# Local only:
# NEXT_PUBLIC_APP_URL=
# Stable ngrok (match ngrok.yml → endpoints.lms.url):
# NEXT_PUBLIC_APP_URL=
