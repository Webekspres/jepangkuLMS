{
  "name": "jepangku-lms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clear": "rm -rf .next && next dev",
    "tunnel": "npm exec --yes -- ngrok@latest http 3000",
    "tunnel:stable": "npm exec --yes -- ngrok@latest start lms --config ./ngrok.yml --config \"$HOME/AppData/Local/ngrok/ngrok.yml\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "bun test",
    "test:unit": "bun test",
    "test:coverage": "bun test --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "db:generate": "prisma generate",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:format": "prisma format",
    "db:reset": "prisma migrate reset",
    "lesson:backfill-types": "bun scripts/backfill-lesson-type.ts",
    "course-import:backfill-external-ids": "bun scripts/backfill-course-import-external-ids.ts",
    "verify:core-gamification": "bun scripts/verify-core-gamification.ts",
    "email:dev": "email dev --dir emails --port 3001",
    "kana:generate": "bun run scripts/generate-kana-manifest-from-xlsx.ts",
    "kana:vocab-images": "bun run scripts/generate-kana-vocab-images.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1077.0",
    "@clerk/nextjs": "^7.5.11",
    "@clerk/themes": "^2.4.57",
    "@clerk/ui": "^1.24.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.10",
    "@tanstack/react-query": "^5.101.2",
    "@types/canvas-confetti": "^1.9.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "html-to-image": "^1.11.13",
    "jose": "^6.2.3",
    "lucide-react": "^1.22.0",
    "motion": "^12.42.2",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "radix-ui": "^1.6.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-easy-crop": "^6.0.2",
    "react-markdown": "^10.1.0",
    "react-player": "^3.4.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.17.1",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "svix": "^1.96.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/exceljs": "^1.3.2",
    "@types/node": "^20.19.43",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "bun-types": "^1.3.14",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "react-email": "^6.6.6",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ],
  "overrides": {
    "@clerk/shared": "4.23.0"
  }
}
